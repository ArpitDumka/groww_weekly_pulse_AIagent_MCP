# Secrets / local config
.env
.env.*
!.env.example
token.json
credentials.json
**/token.json
**/credentials.json

# Virtualenvs
.venv/
venv/
**/__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Local run logs
*.log
phase3_run.log

# Large / regenerable pipeline artifacts (rebuild via weekly run).
# Ignore files inside data/output/, but keep the dirs + the cumulative corpus
# (parent dirs must not be fully ignored or git cannot re-include the file).
**/data/output/*
!**/data/output/.gitkeep
!phase-1-review-ingest/data/output/corpus.json
**/data/raw/*.csv
!**/data/raw/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Hugging Face / model caches (if ever local)
.cache/
