# Weekly Review Pulse — application config
WINDOW_WEEKS=12
MAX_THEMES=5
TOP_THEMES=3
QUOTE_COUNT=3
ACTION_COUNT=3
WORD_BUDGET=250
RECIPIENT=me@example.com
DRY_RUN=false

# MCP server launch (stdio) — set commands for your environment's Google Docs / Gmail MCP servers
# Example shape only; replace with the connector your course provides.
GOOGLE_DOCS_MCP_COMMAND=
GOOGLE_DOCS_MCP_ARGS=
GMAIL_MCP_COMMAND=
GMAIL_MCP_ARGS=

# Tool names to discover (adjust if your MCP server uses different names)
GOOGLE_DOCS_CREATE_TOOL=create_document
GMAIL_CREATE_DRAFT_TOOL=create_draft

# Optional: path to JSON MCP config (overrides individual GOOGLE_* / GMAIL_* env vars when set)
# MCP_SERVERS_CONFIG=config/mcp_servers.json
